{
  "compilerOptions": {
    "target": "ES2020",
    "module": "preserve",
    "moduleResolution": "bundler",
    "esModuleInterop": true,
    "strict": true,
    "skipLibCheck": true,
    "noEmit": true,
    "types": ["node"],
    "paths": {
      "#pages/*": ["./src/tests/pages/*"],
      "#utils/*": ["./src/main/utils/*"],
      "#resources/*": ["./src/main/resources/*"],
      "#constants/*": ["./src/main/resources/constants/*"],
      "#setup/*": ["./src/main/resources/setup/*"],
      "#pagesetup": ["./src/main/resources/setup/page-setup.ts"],
      "#testdata/*": ["./src/tests/testdata/*"],
      "#storage-setup/*": ["./src/tests/storage-setup/*"],
      "#playwright-config": ["./playwright.config.ts"]
    }
  },
  "include": [
    "src/**/*.ts",
    "playwright.config.ts"
  ]
}
